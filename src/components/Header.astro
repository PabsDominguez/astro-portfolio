---
import Sun from "@lucide/astro/icons/sun"
import Moon from "@lucide/astro/icons/moon"
import Computer from "@lucide/astro/icons/computer"

interface Props {
  pathname: string
}

const { pathname } = Astro.props
const isHome = pathname === "/"
---

<header class="mt-6 md:mt-16">
  <nav class="flex items-center justify-between">
    <a
      href="/"
      class="-ml-3 inline-flex h-9 items-center justify-center rounded-md px-3 text-base font-medium hover:bg-accent hover:text-accent-foreground"
    >
      {isHome ? <h1>Pabs Domínguez</h1> : "Pabs Domínguez"}
      {!isHome && <><span class="mx-2 text-2xl font-extralight text-muted-foreground">/</span><span class="text-sm font-normal text-muted-foreground">{pathname.slice(1).replace(/\/$/, '')}</span></>}
    </a>

    <div class="flex items-center">
      <button
        id="theme-toggle"
        type="button"
        class="cursor-pointer text-muted-foreground hover:text-foreground transition-colors p-2 -mr-2 rounded-md"
        aria-label="Toggle theme"
      >
        <Sun class="size-5 hidden dark:hidden crt:block" />
        <Moon class="size-5 block dark:hidden crt:hidden" />
        <Computer class="size-5 hidden dark:block crt:hidden" />
      </button>
    </div>
  </nav>
</header>

<script>
  import { initTheme } from "@/lib/theme"

  // Preserve theme during View Transitions (before swap to prevent flash)
  document.addEventListener("astro:before-swap", (e) => {
    const isDark = document.documentElement.classList.contains("dark")
    const isCrt = document.documentElement.classList.contains("crt")
    e.newDocument.documentElement.classList.toggle("dark", isDark)
    e.newDocument.documentElement.classList.toggle("crt", isCrt)
  })

  initTheme()
  document.addEventListener("astro:page-load", initTheme)
</script>
