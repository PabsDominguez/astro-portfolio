---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="Work - Pablo Dominguez">
  <Nav />
  
  <main class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100">
    <div class="max-w-5xl mx-auto px-6 py-20">
      
      <h1 class="text-5xl font-bold text-slate-900 mb-8">
        My Work
      </h1>
      
      <p class="text-xl text-slate-600 mb-12">
        Featured projects coming soon...
      </p>
      
      <div class="space-y-8">
        <div class="bg-white p-8 rounded-lg shadow-sm border border-slate-200">
          <h3 class="text-2xl font-bold text-slate-900 mb-3">
            Project 1
          </h3>
          <p class="text-slate-600">
            Project description will go here.
          </p>
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-sm border border-slate-200">
          <h3 class="text-2xl font-bold text-slate-900 mb-3">
            Project 2
          </h3>
          <p class="text-slate-600">
            Project description will go here.
          </p>
        </div>
      </div>
      
    </div>
  </main>
</Layout>