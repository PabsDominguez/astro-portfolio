---

<Layout title="Earlier Work | Pabs Dominguez" description="A visual archive of projects from earlier in my career.">
  <section class="mt-6 mb-4">
    <h1 class="text-2xl font-semibold">Earlier Work</h1>
    <p class="mt-3 text-muted-foreground">
      A visual archive of projects I enjoyed working on during my career, going back to my first design work.
    </p>
  </section>

  <ul class="mt-12 space-y-16">
    {projects.map((project, i) => (
      <li class:list={["fade-in-entry opacity-0 translate-y-5 flex flex-col gap-3 sm:items-start sm:gap-6", i % 2 === 0 ? "sm:flex-row" : "sm:flex-row-reverse"]}>
        <!-- Text — full width on mobile, 30% on desktop -->
        <div class="sm:w-[30%] sm:shrink-0 sm:pt-1">
          <h2 class="font-medium">{project.title}</h2>
          <p class="mt-2 text-sm text-muted-foreground">{project.description}</p>
        </div>

        <!-- Cover image — 70%, clicking opens the lightbox -->
        <button
          class="gallery-trigger cover-img w-full sm:w-[70%] sm:shrink-0 cursor-zoom-in"
          data-images={JSON.stringify(project.images.map(img => `/gallery/${img}`))}
          aria-label={`View screenshots for ${project.title}`}
        >
          <img
            src={`/gallery/${project.cover}`}
            alt={project.title}
            class="w-full rounded-sm object-cover"
            loading="lazy"
          />
        </button>
      </li>
    ))}
  </ul>
</Layout>

<!-- Lightbox — full-screen overlay -->
<dialog id="lightbox" class="fixed inset-0 m-0 h-full w-full max-h-none max-w-none overflow-hidden border-0 bg-transparent p-0 backdrop:bg-black/90">
  <!-- Backdrop — clicking here closes -->
  <div id="lightbox-backdrop" class="flex h-full w-full items-center justify-center cursor-zoom-out">
    <!-- Image wrapper — clicks here don't bubble up to backdrop -->
    <div class="relative" id="lightbox-wrapper">
      <!-- X button — top-right corner of the image -->
      <button
        id="lightbox-close"
        class="absolute -top-3 -right-3 z-10 rounded-full bg-black/60 p-1 text-white/70 transition-colors hover:text-white"
        aria-label="Close"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Image — clicking advances to next -->
      <img
        id="lightbox-img"
        src=""
        alt=""
        class="max-h-[88vh] max-w-[88vw] rounded-sm object-contain shadow-2xl select-none cursor-pointer"
      />

      <!-- Counter -->
      <span id="lightbox-counter" class="absolute -bottom-6 left-1/2 -translate-x-1/2 text-xs text-white/50 tabular-nums whitespace-nowrap"></span>
    </div>
  </div>
</dialog>


<script>
  // — Scroll fade-in —
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible")
          observer.unobserve(entry.target)
        }
      })
    },
    { threshold: 0.1 }
  )

  document.querySelectorAll(".fade-in-entry").forEach((el) => observer.observe(el))

  // — Lightbox —
  const dialog = document.getElementById("lightbox") as HTMLDialogElement
  const backdrop = document.getElementById("lightbox-backdrop") as HTMLDivElement
  const img = document.getElementById("lightbox-img") as HTMLImageElement
  const close = document.getElementById("lightbox-close") as HTMLButtonElement
  const counter = document.getElementById("lightbox-counter") as HTMLSpanElement

  let images: string[] = []
  let current = 0

  function show(index: number) {
    current = (index + images.length) % images.length
    img.src = images[current] ?? ""
    counter.textContent = images.length > 1 ? `${current + 1} / ${images.length}` : ""
  }

  function openLightbox(imageList: string[]) {
    images = imageList
    show(0)
    dialog.showModal()
    document.body.style.overflow = "hidden"
  }

  function closeLightbox() {
    dialog.close()
    document.body.style.overflow = ""
  }

  document.querySelectorAll<HTMLButtonElement>(".gallery-trigger").forEach((btn) => {
    btn.addEventListener("click", () => {
      const imageList = JSON.parse(btn.dataset.images || "[]")
      openLightbox(imageList)
    })
  })

  img.addEventListener("click", () => show(current + 1))
  close.addEventListener("click", closeLightbox)

  // Close when clicking the backdrop (outside the image)
  backdrop.addEventListener("click", closeLightbox)
  // Prevent clicks on the image/close button from bubbling up to the backdrop
  img.addEventListener("click", (e) => e.stopPropagation())
  close.addEventListener("click", (e) => e.stopPropagation())

  // Keyboard
  dialog.addEventListener("keydown", (e) => {
    if (e.key === "ArrowLeft") show(current - 1)
    if (e.key === "ArrowRight") show(current + 1)
  })

  // Swipe
  let touchStartX = 0
  img.addEventListener("touchstart", (e) => {
    touchStartX = e.touches[0]?.clientX ?? 0
  }, { passive: true })
  img.addEventListener("touchend", (e) => {
    const delta = (e.changedTouches[0]?.clientX ?? 0) - touchStartX
    if (Math.abs(delta) > 40) {
      delta < 0 ? show(current + 1) : show(current - 1)
    }
  }, { passive: true })
</script>
