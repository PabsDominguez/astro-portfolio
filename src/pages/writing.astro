---
import Layout from "@/layouts/Layout.astro"
import BlogPost from "@/components/BlogPost.astro"
import { formatDate, getSortedPosts } from "@/lib/utils"

const sortedPosts = await getSortedPosts()
---

<Layout title="Writing | Pabs Dominguez" description="Posts, notes, and thoughts">
  <section class="mt-6">
    <h1 class="font-medium mb-5">Writing</h1>
    <p class="text-muted-foreground">Posts, notes, and thoughts.</p>

    <ul class="mt-6 space-y-2">
      {sortedPosts.map((post) => (
        <BlogPost
          href={`/${post.id}`}
          title={post.data.title}
          description={post.data.description}
          date={formatDate(post.data.date, true)}
        />
      ))}
    </ul>
  </section>

</Layout>
