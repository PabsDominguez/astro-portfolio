---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="Pablo Dominguez - Product Designer">
<Nav />
  <main class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100">
    <div class="max-w-5xl mx-auto px-6 py-20">
      
      <!-- Hero Section -->
      <section class="text-center space-y-6">
        <h1 class="text-6xl font-bold text-slate-800">
          Hi, I'm Pablo 👋
        </h1>
        <p class="text-2xl text-slate-00 max-w-2xl mx-auto">
          Product Design Manager specializing in UX/UI design and building delightful digital experiences.
        </p>
        <div class="flex gap-4 justify-center pt-8">
          <a href="#work" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
            View My Work
          </a>
          <a href="#contact" class="bg-slate-200 text-slate-900 px-8 py-3 rounded-lg font-semibold hover:bg-slate-300 transition">
            Get In Touch
          </a>
        </div>
      </section>

    </div>
  </main>
</Layout>